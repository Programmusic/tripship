# Server
PORT=3000
NODE_ENV=development

# Auth — change in production!
JWT_SECRET=your-super-secret-jwt-key

# Database (required on Vercel — use Vercel Postgres, Neon, or Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/tripship

# Vercel Blob (optional — enables DJ mix file uploads on Vercel)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
